# Secrets & local state
.env
*.env.local

# Generated TLS material / private keys / cert bundles — NEVER commit these.
config/proxy/tls/*.pem
*.pem
*.pfx
*.p12
*.key

# Generated Keycloak realm (rendered from scripts/keycloak-realm.json.template)
config/keycloak/*.json

# Backups
backups/

# Air-gapped artifacts (keep the dir, ignore downloaded content)
config/nextcloud/apps-offline/*
!config/nextcloud/apps-offline/.gitkeep
*.tar
magic-workflow-images.tar

# Helm chart packages
helm/**/charts/
*.tgz

# Docs build
MagicWorkflow_Docs/site/
MagicWorkflow_Docs/.venv/
__pycache__/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
