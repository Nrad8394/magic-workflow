# Keep LF on everything that runs inside Linux containers / shells.
*.sh            text eol=lf
*.conf          text eol=lf
*.ini           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.template      text eol=lf
.env.example    text eol=lf
Makefile        text eol=lf
*.ps1           text eol=crlf
