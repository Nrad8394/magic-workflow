<?xml version="1.0" encoding="UTF-8"?>
<!--
  Magic Workflow — IIS (ARR + URL Rewrite) reverse proxy.

  Exposes the suite running on the VM (nginx edge at 192.168.121.148:443) through
  a Windows Server / IIS host (10.153.1.189) so it's reachable on the network.

  Unlike a single-app proxy, Magic Workflow routes 7 services by Host header
  (cloud./chat./id./office./dash./s3./grafana.magic.test), so this rule PRESERVES
  the original Host and forwards over HTTPS — it does NOT override it. Because the
  external hostname == backend hostname and the scheme stays https, no outbound
  redirect rewrite is needed.

  Prerequisites (see docs/windows-iis.md):
    * URL Rewrite 2.1 + Application Request Routing 3.0 installed
    * ARR proxy enabled (ARR Cache > Server Proxy Settings > Enable proxy)
    * WebSocket Protocol feature installed
    * Windows Server hosts file: 192.168.121.148  cloud.magic.test chat.magic.test ...
    * VM edge cert imported into Local Computer > Trusted Root
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxy-MagicWorkflow" stopProcessing="true">
          <match url="(.*)" />
          <!-- Forward to the VM's nginx over HTTPS, KEEPING the original Host
               (cloud.magic.test, id.magic.test, ...) so nginx routes correctly.
               {HTTP_HOST} resolves to the VM via the Windows Server hosts file,
               and the *.magic.test cert matches, so ARR's TLS check passes. -->
          <action type="Rewrite" url="https://{HTTP_HOST}/{R:0}" />
        </rule>
      </rules>
      <!-- No outbound rule needed: the apps already emit https://<their-host>
           URLs, which equal the external host. (Add one only if you change the
           external hostname/scheme.) -->
    </rewrite>

    <!-- Nextcloud / Mattermost large uploads: raise IIS's 30 MB default to 10 GB. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="10737418240" />
      </requestFiltering>
    </security>

    <!-- Don't let IIS swallow backend error bodies (helpful while debugging). -->
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
