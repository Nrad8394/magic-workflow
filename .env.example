# =============================================================================
# Magic Workflow — unified self-hosted collaboration suite
# Copy to `.env` (or run `make setup`) and adjust. Never commit the real .env.
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
TZ=Africa/Nairobi
COMPOSE_PROJECT_NAME=magicworkflow

# Container engine. Leave as docker, or run any make target with ENGINE=podman
# on RHEL/Fedora (see scripts/install-rhel.sh). This var documents the default;
# the actual switch is `make up ENGINE=podman`.
ENGINE=docker

# Optional private-registry / mirror prefix for ALL images (air-gapped installs).
# Empty = pull from the public registries. Include a trailing slash, e.g.
#   IMAGE_REGISTRY=registry.internal.example.com/
# Populate the mirror with: make push-images REGISTRY=registry.internal.example.com/
IMAGE_REGISTRY=

# Base domain. Every service is a subdomain of this.
#   Local:   magic.test   (works in browsers; tests use Host headers)
#   Server:  example.com       (set real DNS A-records for each subdomain below)
BASE_DOMAIN=magic.test

# Per-service hostnames (derived from BASE_DOMAIN by setup.sh; override if needed)
NEXTCLOUD_HOST=cloud.magic.test
MATTERMOST_HOST=chat.magic.test
COLLABORA_HOST=office.magic.test
KEYCLOAK_HOST=id.magic.test
GRAFANA_HOST=grafana.magic.test
HOMER_HOST=dash.magic.test
MINIO_CONSOLE_HOST=s3.magic.test

# TLS scheme: "selfsigned" for local, "letsencrypt" for a real server.
TLS_MODE=selfsigned
# Used only when TLS_MODE=letsencrypt
ACME_EMAIL=admin@example.com

# Host ports for the edge proxy.
HTTP_PORT=80
HTTPS_PORT=443

# ── Image tags (pin for reproducibility) ─────────────────────────────────────
NGINX_IMAGE_TAG=1.27-alpine
POSTGRES_IMAGE_TAG=16-alpine
REDIS_IMAGE_TAG=7-alpine
MINIO_IMAGE_TAG=RELEASE.2025-04-22T22-12-26Z
MC_IMAGE_TAG=RELEASE.2025-04-16T18-13-26Z
KEYCLOAK_IMAGE_TAG=26.1
NEXTCLOUD_IMAGE_TAG=32-fpm
MATTERMOST_IMAGE=mattermost-team-edition
MATTERMOST_IMAGE_TAG=release-10.5
COLLABORA_IMAGE_TAG=latest
PROMETHEUS_IMAGE_TAG=v3.2.1
GRAFANA_IMAGE_TAG=11.5.2
LOKI_IMAGE_TAG=3.4.2
PROMTAIL_IMAGE_TAG=3.4.2
NODE_EXPORTER_IMAGE_TAG=v1.9.0
HOMER_IMAGE_TAG=latest
WATCHTOWER_IMAGE_TAG=1.7.1

# ── PostgreSQL (shared instance, multiple databases) ─────────────────────────
# A superuser; per-app databases + roles are created by config/postgres init.
POSTGRES_SUPER_USER=mwadmin
POSTGRES_SUPER_PASSWORD=change_me_super_pw
# Per-app DB passwords
NEXTCLOUD_DB_PASSWORD=change_me_nc_db_pw
MATTERMOST_DB_PASSWORD=change_me_mm_db_pw
KEYCLOAK_DB_PASSWORD=change_me_kc_db_pw

# ── Redis (shared cache + Nextcloud file locking) ────────────────────────────
# No password: Redis is on the internal-only Docker network (never published).

# ── MinIO (shared S3 object storage) ─────────────────────────────────────────
MINIO_ROOT_USER=mwminio
MINIO_ROOT_PASSWORD=change_me_minio_pw
# Buckets created on first boot
NEXTCLOUD_S3_BUCKET=nextcloud
MATTERMOST_S3_BUCKET=mattermost
# Access keys the apps use (created against the buckets by the init job)
S3_ACCESS_KEY=mw-app-access
S3_SECRET_KEY=change_me_s3_secret

# ── Keycloak (SSO) ───────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_kc_admin_pw
KEYCLOAK_REALM=magicworkflow
# OIDC client secrets (also referenced in the imported realm)
OIDC_NEXTCLOUD_SECRET=change_me_oidc_nc
OIDC_MATTERMOST_SECRET=change_me_oidc_mm

# ── Nextcloud ────────────────────────────────────────────────────────────────
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_nc_admin_pw
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_LIMIT=10G

# ── Collabora ────────────────────────────────────────────────────────────────
COLLABORA_USERNAME=admin
COLLABORA_PASSWORD=change_me_collabora_pw

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_pw
